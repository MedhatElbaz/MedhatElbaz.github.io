<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Medhat Elbaz - Penetration Tester & Security Researcher Portfolio" />
  <meta name="keywords" content="Medhat Elbaz, Penetration Tester, Cybersecurity, Security Researcher, Bug Bounty, TryHackMe, Web Security" />

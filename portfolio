  <link rel="icon" type="image/png" href="favicon.ico" />
  <link rel="apple-touch-icon" href="favicon.png" />
  <title>Medhat Elbaz | Penetration Tester & Security Researcher</title>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

  <style>
    :root {
      --bg: #050805;
      --bg-soft: #0a100a;
      --card: rgba(12, 20, 12, 0.72);
      --card-2: rgba(10, 18, 10, 0.86);
      --text: #f5fff5;
      --text-soft: #c6d3c6;
      --text-muted: #8ea08e;
      --green: #35d335;
      --green-2: #8cff8c;
      --green-3: #1d7d1d;
      --border: rgba(53, 211, 53, 0.18);
      --shadow: rgba(53, 211, 53, 0.18);
      --radius: 24px;
      --radius-sm: 18px;
      --transition: 0.28s ease;
      --container: 1280px;
    }

    [data-theme="light"] {
      --bg: #f6faf6;
      --bg-soft: #edf5ed;
      --card: rgba(255,255,255,0.82);
      --card-2: rgba(248,252,248,0.92);
      --text: #101810;
      --text-soft: #314131;
      --text-muted: #627462;
      --border: rgba(53, 211, 53, 0.2);
      --shadow: rgba(53, 211, 53, 0.14);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.65;
      overflow-x: hidden;
      transition: background .35s ease, color .35s ease;
      cursor: none;
    }

    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; display: block; }
    .container { width: min(100% - 2.4rem, var(--container)); margin-inline: auto; }

    #particles, #gridBg {
      position: fixed; inset: 0; z-index: -3; pointer-events: none;
    }

    body::before {
      content: "";
      position: fixed; inset: 0; z-index: -2; pointer-events: none;
      background:
        radial-gradient(circle at 10% 10%, rgba(53,211,53,.08), transparent 20%),
        radial-gradient(circle at 90% 10%, rgba(53,211,53,.08), transparent 20%),
        radial-gradient(circle at 50% 80%, rgba(53,211,53,.06), transparent 25%);
      animation: bgPulse 10s ease-in-out infinite alternate;
    }

    @keyframes bgPulse {
      0% { transform: scale(1) translateY(0); filter: blur(0px); }
      100% { transform: scale(1.04) translateY(-10px); filter: blur(6px); }
    }

    .cursor-dot, .cursor-ring {
      position: fixed; top: 0; left: 0; pointer-events: none; z-index: 99999; border-radius: 50%;
      transform: translate(-50%, -50%);
      transition: transform .12s ease, width .18s ease, height .18s ease, border-color .2s ease, background .2s ease;
    }
    .cursor-dot { width: 8px; height: 8px; background: var(--green-2); box-shadow: 0 0 16px var(--green); }
    .cursor-ring { width: 34px; height: 34px; border: 1px solid rgba(140,255,140,.45); }
    .cursor-hover .cursor-ring { width: 52px; height: 52px; border-color: rgba(140,255,140,.9); }
    .cursor-hover .cursor-dot { transform: translate(-50%, -50%) scale(1.35); }

    .progress-bar {
      position: fixed; top: 0; left: 0; width: 0%; height: 3px; z-index: 2000;
      background: linear-gradient(90deg, var(--green), var(--green-2)); box-shadow: 0 0 16px var(--green);
    }

    .preloader {
      position: fixed; inset: 0; z-index: 9999; background: #030603;
      display: grid; place-items: center; transition: opacity .8s ease, visibility .8s ease;
    }
    .preloader.hidden { opacity: 0; visibility: hidden; }
    .loader-wrap { width: min(92vw, 560px); text-align: center; }
    .loader-logo {
      font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; letter-spacing: -.04em;
      background: linear-gradient(135deg, #d8ffd8, var(--green)); -webkit-background-clip: text; color: transparent;
      text-shadow: 0 0 24px rgba(53,211,53,.18);
      margin-bottom: 1rem;
    }
    .boot-log {
      text-align: left; font-family: monospace; font-size: .9rem; color: #9ad89a; min-height: 90px;
      background: rgba(53,211,53,.06); border: 1px solid rgba(53,211,53,.12); border-radius: 18px; padding: 1rem 1.1rem; margin-bottom: 1rem;
    }
    .loadbar { height: 10px; background: rgba(255,255,255,.04); border-radius: 999px; overflow: hidden; border: 1px solid var(--border); }
    .loadbar span { display: block; height: 100%; width: 0; background: linear-gradient(90deg, var(--green), var(--green-2)); box-shadow: 0 0 18px var(--green); }

    .navbar {
      position: sticky; top: 0; z-index: 1000;
      background: rgba(5, 8, 5, .72); backdrop-filter: blur(18px); border-bottom: 1px solid var(--border);
    }
    .nav-inner {
      display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1rem 0;
    }
    .logo {
      font-size: 1.35rem; font-weight: 900; letter-spacing: -.03em;
      background: linear-gradient(135deg, #d9ffd9, var(--green)); -webkit-background-clip: text; color: transparent;
      white-space: nowrap;
    }
    .nav-links { display: flex; gap: 1.2rem; list-style: none; flex-wrap: wrap; }
    .nav-links a {
      font-size: .95rem; font-weight: 600; color: var(--text-soft); transition: var(--transition); position: relative;
    }
    .nav-links a:hover, .nav-links a.active { color: var(--green-2); }
    .nav-actions { display: flex; align-items: center; gap: .8rem; }
    .theme-toggle, .nav-cta {
      border: 1px solid var(--border); border-radius: 999px; display: inline-flex; align-items: center; justify-content: center; transition: var(--transition);
    }
    .theme-toggle { width: 42px; height: 42px; background: rgba(53,211,53,.08); }
    .theme-toggle:hover { transform: translateY(-2px) scale(1.04); background: rgba(53,211,53,.15); }
    .nav-cta {
      padding: .72rem 1.15rem; background: rgba(53,211,53,.1); color: var(--green-2); gap: .6rem; font-weight: 700; font-size: .92rem;
    }
    .nav-cta:hover { transform: translateY(-2px); box-shadow: 0 12px 26px rgba(53,211,53,.14); }

    section { padding: 5.5rem 0; position: relative; }
    .section-header { max-width: 780px; margin-bottom: 2.4rem; }
    .section-eyebrow {
      display: inline-flex; align-items: center; gap: .55rem; padding: .4rem .9rem; border-radius: 999px;
      background: rgba(53,211,53,.09); border: 1px solid rgba(53,211,53,.22); color: var(--green-2); font-size: .82rem; font-weight: 800; margin-bottom: 1rem;
    }
    .section-title { font-size: clamp(1.9rem, 4vw, 2.8rem); font-weight: 900; line-height: 1.15; margin-bottom: .9rem; letter-spacing: -.04em; }
    .section-subtitle { color: var(--text-soft); font-size: 1rem; }

    .hero { min-height: calc(100vh - 82px); display: flex; align-items: center; }
    .hero-grid { display: grid; grid-template-columns: 1.2fr .8fr; gap: 2.5rem; align-items: center; width: 100%; }
    .hero-badge {
      display: inline-flex; align-items: center; gap: .55rem; padding: .48rem 1rem; border-radius: 999px;
      background: rgba(53,211,53,.08); border: 1px solid rgba(53,211,53,.22); color: var(--green-2); font-size: .82rem; font-weight: 800; margin-bottom: 1.2rem;
    }
    .hero h1 { font-size: clamp(3rem, 7vw, 5.2rem); line-height: 1.02; font-weight: 900; letter-spacing: -.06em; margin-bottom: .8rem; }
    .hero-highlight {
      background: linear-gradient(135deg, var(--green), var(--green-2)); -webkit-background-clip: text; color: transparent;
    }
    .typed-box {
      border-left: 3px solid var(--green); padding-left: 1rem; min-height: 3.5rem; color: var(--text-soft); font-weight: 700; margin-bottom: 1rem;
    }
    #typed-text { color: var(--green-2); }
    .cursor-blink { animation: blink .8s infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
    .hero-description { max-width: 720px; color: var(--text-soft); font-size: 1.03rem; margin-bottom: 1.6rem; }

    .hero-stats, .mini-list, .social-links, .cert-list { display: flex; flex-wrap: wrap; gap: .9rem; }
    .stat-card, .card, .skills-panel, .terminal-box, .contact-flex, .trust-strip {
      background: var(--card); backdrop-filter: blur(16px); border: 1px solid var(--border);
      box-shadow: 0 16px 40px rgba(0,0,0,.18), inset 0 1px 0 rgba(255,255,255,.02);
    }
    .stat-card {
      padding: 1rem 1.15rem; border-radius: 20px; min-width: 150px; flex: 1; transition: var(--transition);
    }
    .stat-card:hover { transform: translateY(-5px); border-color: rgba(140,255,140,.28); }
    .stat-card h3 { color: var(--green-2); font-size: 1.3rem; margin-bottom: .15rem; }
    .stat-card p { color: var(--text-soft); font-size: .9rem; }

    .btn-group { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1.3rem; }
    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: .6rem; border-radius: 999px; padding: .92rem 1.4rem; font-weight: 800; border: none; cursor: pointer; transition: var(--transition);
    }
    .btn-primary { background: linear-gradient(135deg, var(--green), var(--green-2)); color: #051005; box-shadow: 0 12px 30px rgba(53,211,53,.24); }
    .btn-primary:hover { transform: translateY(-3px); }
    .btn-outline { background: transparent; color: var(--text); border: 1px solid rgba(140,255,140,.24); }
    .btn-outline:hover { background: rgba(53,211,53,.08); transform: translateY(-3px); }

    .hero-image { position: relative; display: flex; justify-content: center; }
    .profile-frame {
      position: relative; width: min(100%, 380px); border-radius: 32px; padding: .8rem; overflow: hidden;
      background: linear-gradient(145deg, rgba(6,16,6,.95), rgba(3,12,3,.95)); border: 1px solid rgba(53,211,53,.28);
      box-shadow: 0 28px 60px rgba(0,0,0,.35), 0 0 0 1px rgba(53,211,53,.08);
    }
    .profile-frame::before {
      content: ""; position: absolute; inset: -40%; background: conic-gradient(from 0deg, transparent, rgba(53,211,53,.16), transparent 30%, transparent 60%, rgba(140,255,140,.16), transparent);
      animation: spin 8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .profile-frame::after {
      content: ""; position: absolute; inset: 0; background: linear-gradient(transparent 60%, rgba(53,211,53,.06)); pointer-events: none;
    }
    .scan-line {
      position: absolute; inset: 0; background: linear-gradient(to bottom, transparent, rgba(140,255,140,.08), transparent); height: 20%; animation: scan 4s linear infinite; z-index: 2; pointer-events: none;
    }
    @keyframes scan { 0%{transform: translateY(-100%)} 100%{transform: translateY(500%)} }
    .profile-img { position: relative; z-index: 1; width: 100%; aspect-ratio: 1/1; object-fit: cover; border-radius: 26px; }

    .availability {
      display: inline-flex; align-items: center; gap: .55rem; margin-top: 1rem; padding: .55rem 1rem; border-radius: 999px; background: rgba(53,211,53,.08); border: 1px solid rgba(53,211,53,.18);
    }
    .status-dot { width: 9px; height: 9px; border-radius: 50%; background: var(--green-2); box-shadow: 0 0 14px var(--green); animation: pulse 1.5s infinite; }
    @keyframes pulse { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(1.2);opacity:.55} }

    .trust-strip { border-radius: 24px; padding: 1.4rem 1.6rem; margin-top: 1rem; }
    .trust-logos { display: flex; flex-wrap: wrap; gap: 1rem 1.8rem; margin-top: 1rem; color: var(--text-muted); font-weight: 700; }

    .about-wrapper, .contact-flex { display: grid; grid-template-columns: 1.2fr .8fr; gap: 1.5rem; }
    .highlight-box, .terminal-box {
      border-radius: 20px; padding: 1.15rem 1.25rem; margin: 1.3rem 0; border: 1px solid var(--border);
      background: linear-gradient(145deg, rgba(53,211,53,.05), rgba(255,255,255,.02));
    }
    .skills-panel { border-radius: 28px; padding: 1.6rem; }
    .skills-grid { display: flex; flex-wrap: wrap; gap: .75rem; }
    .skill-tag {
      padding: .55rem .95rem; border-radius: 999px; background: rgba(53,211,53,.08); border: 1px solid rgba(53,211,53,.22); font-weight: 700; font-size: .84rem; transition: var(--transition);
    }
    .skill-tag:hover { transform: translateY(-2px); border-color: rgba(140,255,140,.35); }

    .skills-bars { margin-top: 1.4rem; display: grid; gap: .9rem; }
    .skill-bar .top { display: flex; justify-content: space-between; margin-bottom: .45rem; font-size: .9rem; }
    .bar-track { height: 10px; background: rgba(255,255,255,.05); border-radius: 999px; overflow: hidden; border: 1px solid rgba(53,211,53,.12); }
    .bar-fill { height: 100%; width: 0; border-radius: 999px; background: linear-gradient(90deg, var(--green), var(--green-2)); box-shadow: 0 0 18px rgba(53,211,53,.28); transition: width 1.4s cubic-bezier(.2,.8,.2,1); }

    .grid-cards { display: grid; gap: 1.4rem; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
    .card {
      border-radius: 24px; padding: 1.5rem; transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease; transform-style: preserve-3d;
    }
    .card:hover { transform: translateY(-6px); border-color: rgba(140,255,140,.3); box-shadow: 0 24px 40px rgba(0,0,0,.22), 0 0 0 1px rgba(53,211,53,.06); }
    .card h3 { font-size: 1.12rem; margin-bottom: .55rem; font-weight: 800; }
    .card p { color: var(--text-soft); font-size: .94rem; }
    .card-meta { color: var(--text-muted); font-size: .85rem; margin-bottom: .9rem; display: flex; flex-wrap: wrap; gap: .55rem; }
    .mini-badge {
      padding: .38rem .8rem; border-radius: 999px; background: rgba(53,211,53,.07); border: 1px solid rgba(53,211,53,.18); font-size: .78rem; font-weight: 700; color: var(--text-soft);
    }
    .icon-glow { color: var(--green-2); margin-right: .35rem; }

    .terminal-box { font-family: monospace; color: #b8f5b8; }
    .terminal-box .line { opacity: .9; }
    .terminal-box .prompt { color: var(--green-2); }

    .projects-controls { display: flex; flex-wrap: wrap; gap: .8rem; margin-bottom: 1.4rem; }
    .filter-btn {
      padding: .7rem 1rem; border-radius: 999px; border: 1px solid var(--border); background: rgba(53,211,53,.05); color: var(--text-soft); font-weight: 700; cursor: pointer; transition: var(--transition);
    }
    .filter-btn.active, .filter-btn:hover { background: rgba(53,211,53,.12); color: var(--green-2); }

    .timeline { display: grid; gap: 1.2rem; }
    .timeline-item {
      position: relative; padding: 1.25rem 1.25rem 1.25rem 3.1rem; border-radius: 22px; background: var(--card); border: 1px solid var(--border);
    }
    .timeline-item::before {
      content: ""; position: absolute; left: 1.15rem; top: 1.35rem; width: 14px; height: 14px; border-radius: 50%; background: var(--green-2); box-shadow: 0 0 18px var(--green);
    }
    .timeline-item::after {
      content: ""; position: absolute; left: 1.78rem; top: 2.2rem; width: 2px; height: calc(100% + .8rem); background: rgba(53,211,53,.16);
    }
    .timeline-item:last-child::after { display: none; }

    .contact-flex { border-radius: 32px; padding: 1.8rem; }
    .contact-info h3 { font-size: 1.7rem; margin-bottom: .7rem; }
    .contact-details { margin-top: 1.2rem; display: grid; gap: .9rem; }
    .contact-details a { display: flex; align-items: center; gap: .85rem; flex-wrap: wrap; color: var(--text-soft); }
    .contact-details a:hover { color: var(--green-2); }
    .contact-icon {
      width: 42px; height: 42px; display: grid; place-items: center; border-radius: 14px; background: rgba(53,211,53,.08); border: 1px solid var(--border); color: var(--green-2);
    }
    .social-link {
      border: 1px solid var(--border); padding: .82rem 1.15rem; border-radius: 999px; transition: var(--transition);
      font-size: .92rem; display: inline-flex; align-items: center; justify-content: center; gap: 10px; min-width: 150px; background: rgba(255,255,255,.025); box-shadow: inset 0 0 0 1px rgba(255,255,255,.015); font-weight: 700; position: relative; overflow: hidden;
    }
    .social-link:hover { background: var(--green); color: #000; border-color: var(--green); transform: translateY(-4px) scale(1.02); box-shadow: 0 12px 26px rgba(46, 204, 46, 0.22); }
    .social-link i { font-size: 1rem; width: 18px; text-align: center; }
    .social-link::before { content: ""; position: absolute; inset: 0; background: linear-gradient(120deg, transparent, rgba(255,255,255,.12), transparent); transform: translateX(-120%); transition: .6s ease; }
    .social-link:hover::before { transform: translateX(120%); }

    .contact-form-wrap {
      background: rgba(255,255,255,.02); border-radius: 26px; padding: 1.5rem; border: 1px solid var(--border);
    }
    .form-title { font-weight: 800; margin-bottom: 1rem; }
    .contact-form { display: grid; gap: 1rem; }
    .contact-form input, .contact-form textarea {
      width: 100%; padding: 14px 16px; border-radius: 16px; border: 1px solid rgba(53,211,53,.16); background: rgba(0,0,0,.2); color: var(--text); outline: none; font-family: inherit;
    }
    .contact-form input:focus, .contact-form textarea:focus { border-color: var(--green); box-shadow: 0 0 0 4px rgba(53,211,53,.08); }
    .contact-form textarea { min-height: 140px; resize: vertical; }
    .form-note { color: var(--text-muted); font-size: .78rem; margin-top: .9rem; }

    .fab {
      position: fixed; right: 1.6rem; bottom: 1.6rem; width: 52px; height: 52px; border-radius: 50%; display: grid; place-items: center; background: linear-gradient(135deg, var(--green), var(--green-2)); color: #071007; box-shadow: 0 18px 28px rgba(53,211,53,.22); z-index: 999; opacity: 0; visibility: hidden; transition: var(--transition);
    }
    .fab.show { opacity: 1; visibility: visible; }
    .fab:hover { transform: translateY(-4px) scale(1.04); }

    footer { padding: 2.4rem 0 3rem; text-align: center; color: var(--text-muted); font-size: .88rem; }
    .reveal { opacity: 0; transform: translateY(30px); transition: opacity .8s ease, transform .8s ease; }
    .reveal.show { opacity: 1; transform: translateY(0); }

    @media (max-width: 980px) {
      .hero-grid, .about-wrapper, .contact-flex { grid-template-columns: 1fr; }
      .nav-inner { flex-wrap: wrap; justify-content: center; }
      .nav-links { justify-content: center; }
      body { cursor: auto; }
      .cursor-dot, .cursor-ring { display: none; }
    }

    @media (max-width: 780px) {
      .hero { min-height: auto; padding-top: 2rem; }
      .hero-grid { text-align: center; }
      .typed-box { border-left: none; border-top: 3px solid var(--green); padding-left: 0; padding-top: .9rem; }
      .btn-group, .hero-stats, .social-links, .mini-list, .trust-logos { justify-content: center; }
      .nav-links { gap: .9rem; }
      .social-link { width: 100%; min-width: 100%; }
    }
  </style>
</head>
